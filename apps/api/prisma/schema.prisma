generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  HR_MANAGER
  PAYROLL_APPROVER
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  PENDING
  INVITED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ContractType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  PROBATION
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  OTHER
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

enum ProbationReviewStatus {
  DRAFT
  PENDING_HR
  DECIDED
  CANCELLED
}

enum ProbationOutcome {
  CONFIRM
  EXTEND
  FAIL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  RETURNED
}

enum ApproverType {
  MANAGER
  DEPARTMENT_HEAD
  ROLE
  SPECIFIC_USER
}

enum ApprovalDecision {
  APPROVED
  RETURNED
  AUTO_SKIPPED
  REJECTED // SPEC-041: từ chối terminal (chỉ Payment dùng; Leave/OT chỉ dùng RETURNED)
}

enum OvertimeCategory {
  OT_WEEKDAY
  OT_WEEKEND
  OT_HOLIDAY
}

enum OvertimeStatus {
  PENDING
  APPROVED
  REJECTED // legacy: chỉ tồn tại cho dữ liệu cũ; flow mới dùng RETURNED thay cho reject
  CANCELLED
  RETURNED
}

// Phân biệt luồng duyệt theo nghiệp vụ. Cùng cấu trúc ApprovalFlow/ApprovalStep
// nhưng OT cấu hình độc lập với Leave.
enum ApprovalFlowType {
  LEAVE
  OVERTIME
  PAYMENT // SPEC-041: luồng duyệt yêu cầu thanh toán (cố định NV → Quản lý → Founder)
  PURCHASE // SPEC-042: luồng duyệt đề xuất mua hàng (cố định NV → Quản lý → Founder)
  KPI_REVIEW // SPEC-044: luồng duyệt review KPI (Quản lý → HR calibrate → finalize)
}

// SPEC-041: loại yêu cầu thanh toán
enum PaymentRequestType {
  REIMBURSEMENT // hoàn ứng — đã chi, xin lại tiền (kèm hoá đơn/bill)
  ADVANCE // tạm ứng — xin tiền trước khi chi
  VENDOR_PAYMENT // thanh toán nhà cung cấp theo hoá đơn đỏ (VAT)
}

// SPEC-041: vòng đời đơn thanh toán
enum PaymentRequestStatus {
  PENDING // đang chờ duyệt ở bước hiện tại
  APPROVED // đã duyệt hết các bước, chờ chi trả
  REJECTED // bị từ chối hẳn (terminal)
  RETURNED // bị trả về để sửa & gửi lại
  CANCELLED // người tạo tự huỷ
  PAID // đã thanh toán (terminal)
}

enum AttendanceSource {
  SELF
  MANUAL_ADJUST
}

enum PayrollRunStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
  CANCELLED
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  UNDER_MAINTENANCE
  RETIRED // thanh lý
  LOST // mất / hỏng không phục hồi
}

enum AssetAssignmentStatus {
  ACTIVE
  RETURNED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
}

// Handover acknowledgement state of an assignment (biên bản bàn giao). An
// assignment is created PENDING (assign-now/sign-later) and becomes SIGNED once
// the recipient acknowledges — on-screen during in-person handover or remotely
// from their own account.
enum AssetAckStatus {
  PENDING
  SIGNED
}

enum AssetAckMethod {
  ON_SCREEN // chữ ký vẽ tay trên màn hình lúc bàn giao trực tiếp
  IN_APP // người nhận tự xác nhận từ xa qua tài khoản
}

// Which figure the employee-side insurance percentages apply to. Vietnamese
// practice usually bases statutory insurance on a contractual base salary
// (BASE_SALARY), but GROSS is offered for tenants that compute on total gross.
enum InsuranceBase {
  GROSS
  BASE_SALARY
}

// ===== Recruitment / ATS (SPEC-024) =====

enum JobStatus {
  DRAFT
  OPEN
  ON_HOLD
  CLOSED
  CANCELLED
}

enum JobEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

// Loại stage chuẩn hóa — tên stage tùy biến được nhưng `type` cố định để analytics
// (conversion/velocity) gộp đúng nhóm dù mỗi job đặt tên khác nhau.
enum StageType {
  SOURCED
  SCREEN
  ASSESSMENT
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum CandidateSource {
  CAREER_SITE
  JOB_BOARD
  REFERRAL
  SOURCED
  AGENCY
  EVENT
  DIRECT
}

// Disposition cố định của hồ sơ ứng tuyển — TÁCH biệt với stage (vị trí trong phễu).
// Khi REJECTED vẫn giữ currentStageId để biết "rớt ở bước nào".
enum ApplicationStatus {
  ACTIVE
  HIRED
  REJECTED
  WITHDRAWN
  ON_HOLD
}

enum RejectionReason {
  UNDERQUALIFIED
  OVERQUALIFIED
  FAILED_ASSESSMENT
  CULTURE_FIT
  COMP_MISMATCH
  POSITION_FILLED
  CANDIDATE_WITHDREW
  NO_SHOW
  OTHER
}

enum AttachmentKind {
  CV
  COVER_LETTER
  OTHER
}

enum ParseStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

// Bulk CV intake (SPEC-027) — staging-table import. Batch = 1 lần kéo-thả nhiều CV
// vào 1 job; item = 1 CV. KHÔNG ghi nháp vào Candidate; chỉ tạo Candidate khi confirm.
enum BulkImportStatus {
  DRAFT
  REVIEWING
  CONFIRMED
  CANCELLED
}

enum BulkImportItemStatus {
  PARSING
  PARSED
  PARSE_FAILED
  CONFIRMED
  SKIPPED
  FAILED
}

// Quyết định của HR cho mỗi item khi confirm: tạo mới, gắn vào candidate đã có, hoặc bỏ.
enum BulkImportItemResolution {
  NEW
  LINK_EXISTING
  SKIP
}

enum InterviewMode {
  ONSITE
  VIDEO
  PHONE
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ScorecardOverall {
  STRONG_NO
  NO
  YES
  STRONG_YES
}

enum HiringTeamRole {
  RECRUITER
  HIRING_MANAGER
  INTERVIEWER
  COORDINATOR
}

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  customDomain String?  @map("custom_domain")
  settings     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users          User[]
  departments    Department[]
  positions      Position[]
  employees      Employee[]
  roles          Role[]
  leaveTypes     LeaveType[]
  leaveRequests  LeaveRequest[]
  leaveBalances  LeaveBalance[]
  approvalFlows  ApprovalFlow[]
  leaveApprovals LeaveApproval[]
  domains        TenantDomain[]

  timesheetPolicy   TimesheetPolicy?
  holidays          Holiday[]
  attendanceRecords AttendanceRecord[]
  overtimeRequests  OvertimeRequest[]

  payrollSettings  PayrollSettings?
  employeeSalaries EmployeeSalary[]
  payrollRuns      PayrollRun[]
  payslips         Payslip[]

  contracts     Contract[]
  notifications Notification[]

  assetCategories   AssetCategory[]
  assets            Asset[]
  assetAssignments  AssetAssignment[]
  assetMaintenances AssetMaintenance[]
  OvertimeApproval  OvertimeApproval[]

  paymentRequests         PaymentRequest[]
  paymentRequestApprovals PaymentRequestApproval[]

  purchaseRequests         PurchaseRequest[]
  purchaseRequestApprovals PurchaseRequestApproval[]
  issuingEntities          IssuingEntity[]

  pipelineTemplates PipelineTemplate[]
  jobs              Job[]
  candidates        Candidate[]
  applications      Application[]
  interviews        Interview[]

  probationCriteria   ProbationCriteria[]
  probationReviews    ProbationReview[]
  probationGuidelines ProbationGuideline[]
  settingsAuditLogs   SettingsAuditLog[]

  // SPEC-044: KPI / Performance Management
  teams                   Team[]
  kpiFrameworks           KpiFramework[]
  kpiCycles               KpiCycle[]
  kpiScorecards           KpiScorecard[]
  kpiScorecardApprovals   KpiScorecardApproval[]
  kpiEntries              KpiEntry[]
  kpiSurveys              KpiSurvey[]
  kpiSurveyResponses      KpiSurveyResponse[]
  kpiSurveyParticipations KpiSurveyParticipation[]

  // SPEC-045: Sales / CRM
  salesCompanies      SalesCompany[]
  customers           Customer[]
  salesPipelines      SalesPipeline[]
  deals               Deal[]
  products            Product[]
  quotes              Quote[]
  salesActivities     SalesActivity[]
  salesTasks          SalesTask[]
  salesEmailTemplates SalesEmailTemplate[]
  salesEmailMessages  SalesEmailMessage[]

  // SPEC-048: Ngân sách & Dòng tiền
  fundAccounts      FundAccount[]
  financeCategories FinanceCategory[]
  cashTransactions  CashTransaction[]
  spendingPlans     SpendingPlan[] // GĐ2
  topUpRequests     TopUpRequest[] // GĐ3

  @@map("tenants")
}

// SPEC-036: ai đổi cấu hình tenant nào, khi nào — ghi mỗi lần PATCH /settings/*.
model SettingsAuditLog {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  section   String
  // { fieldName: { from, to } } — chỉ các field thực sự thay đổi.
  changes   Json
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@map("settings_audit_logs")
}

// Email domains owned by a tenant. Used to resolve which tenant a Google
// Workspace SSO login belongs to: the domain of the verified Google email
// (e.g. "codecrush.asia") maps to exactly one tenant. `domain` is globally
// unique so two tenants can never claim the same domain (cross-tenant takeover).
model TenantDomain {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  domain    String   @unique // lowercased, no "@" — e.g. "codecrush.asia"
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("tenant_domains")
}

model User {
  id                   String     @id @default(cuid())
  tenantId             String     @map("tenant_id")
  email                String
  passwordHash         String     @map("password_hash")
  fullName             String     @map("full_name")
  role                 UserRole   @default(EMPLOYEE)
  roleId               String?    @map("role_id")
  status               UserStatus @default(PENDING)
  emailVerifiedAt      DateTime?  @map("email_verified_at")
  lastLoginAt          DateTime?  @map("last_login_at")
  // SPEC-037: lần đầu đăng nhập Google thành công — hiển thị "đã liên kết SSO".
  googleLinkedAt       DateTime?  @map("google_linked_at")
  // SPEC-037: { [reminderKind]: boolean } — thiếu key = nhận email. Chỉ áp cho
  // email nhắc việc; in-app notification không bị tắt.
  notificationPrefs    Json?      @map("notification_prefs")
  // Invite/set-password flow: users created via bulk import have no usable
  // password until they set one via an emailed token. inviteToken stores a
  // sha256 HASH of the raw token (never the plaintext), single-use.
  inviteToken          String?    @map("invite_token")
  inviteTokenExpiresAt DateTime?  @map("invite_token_expires_at")
  passwordSetAt        DateTime?  @map("password_set_at")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleRef           Role?              @relation(fields: [roleId], references: [id])
  refreshTokens     RefreshToken[]
  employee          Employee?
  notifications     Notification[]
  settingsAuditLogs SettingsAuditLog[]

  @@unique([tenantId, email])
  @@index([email])
  @@index([roleId])
  @@index([inviteToken])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  // Whether the login was "remember me": a persistent cookie (true) vs a
  // browser-session cookie (false). Stored so token rotation on /auth/refresh
  // can re-issue the same cookie type — a session cookie sends no expiry back.
  persistent Boolean   @default(true) @map("persistent")
  // SPEC-037: hiển thị "phiên đăng nhập" trong /account.
  userAgent  String?   @map("user_agent")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
  @@map("refresh_tokens")
}

model Department {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  managerId   String?  @map("manager_id") // trưởng phòng ban (department head)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant           Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  positions        Position[]
  employees        Employee[]               @relation("DepartmentMembers")
  manager          Employee?                @relation("DepartmentHead", fields: [managerId], references: [id])
  approvalFlows    ApprovalFlow[]
  jobs             Job[]
  teams            Team[] // SPEC-044
  kpiAssignments   KpiFrameworkAssignment[] // SPEC-044
  cashTransactions CashTransaction[] // SPEC-048
  spendingPlans    SpendingPlan[] // SPEC-048 GĐ2

  @@unique([tenantId, name])
  @@index([managerId])
  @@map("departments")
}

model Position {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  departmentId String?  @map("department_id")
  name         String
  level        Int      @default(1)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  employees  Employee[]
  jobs       Job[]

  @@unique([tenantId, name])
  @@index([departmentId])
  @@map("positions")
}

model Employee {
  id               String         @id @default(cuid())
  tenantId         String         @map("tenant_id")
  userId           String         @unique @map("user_id")
  employeeCode     String         @map("employee_code")
  departmentId     String?        @map("department_id")
  positionId       String?        @map("position_id")
  managerId        String?        @map("manager_id") // quản lý trực tiếp (direct manager)
  fullName         String         @map("full_name")
  dateOfBirth      DateTime?      @map("date_of_birth")
  gender           Gender?
  idNumber         String?        @map("id_number")
  idIssueDate      DateTime?      @map("id_issue_date") // ngày cấp CCCD/Passport
  idIssuePlace     String?        @map("id_issue_place") // nơi cấp CCCD/Passport
  phone            String?
  personalEmail    String?        @map("personal_email") // email cá nhân (khác email đăng nhập)
  placeOfBirth     String?        @map("place_of_birth")
  maritalStatus    MaritalStatus? @map("marital_status")
  education        String? // trình độ học vấn / chuyên ngành
  permanentAddress String?        @map("permanent_address")
  currentAddress   String?        @map("current_address")
  avatar           String?
  joinDate         DateTime       @map("join_date")
  probationEndDate DateTime?      @map("probation_end_date") // ngày hết thử việc (HR nhập tay; null nếu không áp dụng)
  contractType     ContractType   @map("contract_type")
  dependentsCount  Int            @default(0) @map("dependents_count") // người phụ thuộc — giảm trừ thuế TNCN

  // Liên hệ khẩn cấp
  emergencyContactName         String? @map("emergency_contact_name")
  emergencyContactRelationship String? @map("emergency_contact_relationship")
  emergencyContactPhone        String? @map("emergency_contact_phone")

  // Ngân hàng
  bankAccountNumber String? @map("bank_account_number")
  bankName          String? @map("bank_name")
  bankBranch        String? @map("bank_branch")

  // Thuế & bảo hiểm
  taxCode               String? @map("tax_code")
  socialInsuranceNumber String? @map("social_insurance_number")
  healthcareFacility    String? @map("healthcare_facility") // nơi đăng ký khám chữa bệnh

  // Khác
  motorbikeRegistration String? @map("motorbike_registration") // loại xe - màu - biển số

  status            EmployeeStatus @default(ACTIVE)
  terminatedAt      DateTime?      @map("terminated_at")
  terminationReason String?        @map("termination_reason")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  teamId String? @map("team_id") // SPEC-044: squad/team trong phòng ban

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])
  position   Position?   @relation(fields: [positionId], references: [id])

  manager           Employee?    @relation("EmployeeManager", fields: [managerId], references: [id])
  reports           Employee[]   @relation("EmployeeManager")
  headedDepartments Department[] @relation("DepartmentHead")

  team     Team?  @relation("TeamMembers", fields: [teamId], references: [id]) // SPEC-044
  ledTeams Team[] @relation("TeamLead") // SPEC-044

  kpiScorecards         KpiScorecard[] @relation("KpiScorecardEmployee") // SPEC-044
  kpiScorecardsReviewed KpiScorecard[] @relation("KpiScorecardReviewer") // SPEC-044

  leaveRequests    LeaveRequest[] @relation("EmployeeLeaveRequests")
  reviewedRequests LeaveRequest[] @relation("ReviewerLeaveRequests")
  leaveBalances    LeaveBalance[]

  stepApprovals         ApprovalStep[]    @relation("StepSpecificApprover")
  watchingFlows         ApprovalWatcher[] @relation("WatcherEmployee") // SPEC-046
  leaveApprovalsDecided LeaveApproval[]   @relation("LeaveApprovalDecider")

  attendanceRecords        AttendanceRecord[] @relation("EmployeeAttendance")
  adjustedAttendance       AttendanceRecord[] @relation("AttendanceAdjuster")
  overtimeRequests         OvertimeRequest[]  @relation("EmployeeOvertime")
  reviewedOvertime         OvertimeRequest[]  @relation("OvertimeReviewer")
  overtimeApprovalsDecided OvertimeApproval[] @relation("OvertimeApprovalDecider")

  paymentRequests         PaymentRequest[]         @relation("EmployeePaymentRequests")
  paymentRequestsReviewed PaymentRequest[]         @relation("PaymentRequestReviewer")
  paymentRequestsPaid     PaymentRequest[]         @relation("PaymentRequestPayer")
  paymentApprovalsDecided PaymentRequestApproval[] @relation("PaymentApprovalDecider")

  purchaseRequests        PurchaseRequest[]         @relation("EmployeePurchaseRequests")
  purchaseReviewed        PurchaseRequest[]         @relation("PurchaseRequestReviewer")
  purchaseOrdered         PurchaseRequest[]         @relation("PurchaseRequestOrderer")
  purchaseApprovalDecided PurchaseRequestApproval[] @relation("PurchaseApprovalDecider")

  salaries        EmployeeSalary[] @relation("EmployeeSalaries")
  salariesCreated EmployeeSalary[] @relation("SalaryCreator")
  payslips        Payslip[]        @relation("EmployeePayslips")

  contracts Contract[] @relation("EmployeeContracts")

  assetsHeld        AssetAssignment[]  @relation("AssetHolder")
  assetsAssigned    AssetAssignment[]  @relation("AssetAssigner")
  assetsReturned    AssetAssignment[]  @relation("AssetReturner")
  assetMaintenances AssetMaintenance[] @relation("MaintenanceCreator")

  jobsCreated           Job[]                     @relation("JobCreator")
  hiringTeamMemberships JobHiringTeam[]           @relation("HiringTeamMember")
  stageChanges          ApplicationStageHistory[] @relation("StageChanger")
  interviewsCreated     Interview[]               @relation("InterviewCreator")
  interviewAssignments  InterviewInterviewer[]    @relation("InterviewerAssignment")
  scorecards            Scorecard[]               @relation("ScorecardInterviewer")
  applicationActivities ApplicationActivity[]     @relation("ActivityAuthor")

  probationReviews        ProbationReview[] @relation("EmployeeProbationReviews")
  probationReviewsGiven   ProbationReview[] @relation("ProbationReviewer")
  probationReviewsDecided ProbationReview[] @relation("ProbationDecider")

  // SPEC-045: Sales / CRM — owner/assignee/author/sender
  customersOwned     Customer[]          @relation("CustomerOwner")
  dealsOwned         Deal[]              @relation("DealOwner")
  dealStageChanges   DealStageHistory[]  @relation("DealStageChanger")
  salesActivities    SalesActivity[]     @relation("SalesActivityAuthor")
  salesTasksAssigned SalesTask[]         @relation("SalesTaskAssignee")
  salesEmailsSent    SalesEmailMessage[] @relation("SalesEmailSender")

  @@unique([tenantId, employeeCode])
  @@index([tenantId, status])
  @@index([departmentId])
  @@index([positionId])
  @@index([managerId])
  @@map("employees")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  key         String
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  permissions RolePermission[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id       String @id @default(cuid())
  key      String @unique
  resource String
  action   String

  roles RolePermission[]

  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model LeaveType {
  id                 String   @id @default(cuid())
  tenantId           String   @map("tenant_id")
  name               String
  code               String
  colorHex           String?  @map("color_hex")
  defaultDays        Float    @default(0) @map("default_days")
  paid               Boolean  @default(true)
  requiresAttachment Boolean  @default(false) @map("requires_attachment")
  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requests LeaveRequest[]
  balances LeaveBalance[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("leave_types")
}

model LeaveRequest {
  id            String      @id @default(cuid())
  tenantId      String      @map("tenant_id")
  employeeId    String      @map("employee_id")
  leaveTypeId   String      @map("leave_type_id")
  startDate     DateTime    @map("start_date")
  endDate       DateTime    @map("end_date")
  halfDay       Boolean     @default(false) @map("half_day")
  totalDays     Float       @map("total_days")
  reason        String?
  attachmentUrl String?     @map("attachment_url")
  status        LeaveStatus @default(PENDING)
  flowId        String?     @map("flow_id")
  currentStep   Int         @default(0) @map("current_step")
  reviewedById  String?     @map("reviewed_by_id")
  reviewedAt    DateTime?   @map("reviewed_at")
  reviewNote    String?     @map("review_note")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   Employee        @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy Employee?       @relation("ReviewerLeaveRequests", fields: [reviewedById], references: [id])
  leaveType  LeaveType       @relation(fields: [leaveTypeId], references: [id])
  flow       ApprovalFlow?   @relation(fields: [flowId], references: [id])
  approvals  LeaveApproval[]

  @@index([tenantId, status])
  @@index([employeeId])
  @@index([leaveTypeId])
  @@index([flowId])
  @@map("leave_requests")
}

model LeaveBalance {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  employeeId  String   @map("employee_id")
  leaveTypeId String   @map("leave_type_id")
  year        Int
  allocated   Float    @default(0)
  used        Float    @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, leaveTypeId, year])
  @@index([employeeId, year])
  @@map("leave_balances")
}

model ApprovalFlow {
  id           String           @id @default(cuid())
  tenantId     String           @map("tenant_id")
  departmentId String?          @map("department_id") // null = luồng mặc định của tenant (tenant default)
  flowType     ApprovalFlowType @default(LEAVE) @map("flow_type")
  name         String
  active       Boolean          @default(true)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department       Department?       @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  steps            ApprovalStep[]
  watchers         ApprovalWatcher[] // SPEC-046: CC/người theo dõi (chỉ xem, không duyệt)
  requests         LeaveRequest[]
  otRequests       OvertimeRequest[]
  paymentRequests  PaymentRequest[]
  purchaseRequests PurchaseRequest[]
  kpiScorecards    KpiScorecard[] // SPEC-044

  // NOTE: Postgres coi mỗi NULL là khác nhau nên unique này KHÔNG ép một
  // default duy nhất/tenant/flowType — ràng buộc single-default enforce ở service layer.
  @@unique([tenantId, departmentId, flowType])
  @@index([tenantId])
  @@map("approval_flows")
}

model ApprovalStep {
  id           String       @id @default(cuid())
  flowId       String       @map("flow_id")
  stepOrder    Int          @map("step_order")
  approverType ApproverType @map("approver_type")
  roleKey      String?      @map("role_key") // khi approverType = ROLE
  approverId   String?      @map("approver_id") // khi approverType = SPECIFIC_USER
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  flow     ApprovalFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  approver Employee?    @relation("StepSpecificApprover", fields: [approverId], references: [id])

  @@unique([flowId, stepOrder])
  @@index([flowId])
  @@map("approval_steps")
}

// SPEC-046: CC / người theo dõi gắn vào một ApprovalFlow. Watcher XEM được mọi đơn
// đi qua flow này ở mọi trạng thái nhưng KHÔNG nằm trong ApprovalStep/LeaveApproval →
// matchesApprover() không bao giờ khớp → về bản chất không thể duyệt/từ chối.
// Resolve động từ flow tại thời điểm xem (không snapshot per-request).
model ApprovalWatcher {
  id          String       @id @default(cuid())
  flowId      String       @map("flow_id")
  watcherType ApproverType @map("watcher_type") // dùng lại enum: chỉ ROLE | SPECIFIC_USER
  roleKey     String?      @map("role_key") // khi watcherType = ROLE (Role.key của custom role)
  watcherId   String?      @map("watcher_id") // khi watcherType = SPECIFIC_USER (Employee.id)
  createdAt   DateTime     @default(now()) @map("created_at")

  flow    ApprovalFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  watcher Employee?    @relation("WatcherEmployee", fields: [watcherId], references: [id])

  @@index([flowId])
  @@map("approval_watchers")
}

model LeaveApproval {
  id           String            @id @default(cuid())
  tenantId     String            @map("tenant_id")
  requestId    String            @map("request_id")
  round        Int               @default(1) // tăng mỗi lần đơn bị trả về rồi nộp lại
  stepOrder    Int               @map("step_order")
  approverType ApproverType      @map("approver_type")
  roleKey      String?           @map("role_key")
  approverId   String?           @map("approver_id") // người duyệt kỳ vọng (resolved); null nếu không xác định được
  decision     ApprovalDecision? // null = đang chờ (pending)
  decidedById  String?           @map("decided_by_id")
  decidedAt    DateTime?         @map("decided_at")
  note         String?
  createdAt    DateTime          @default(now()) @map("created_at")

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  request   LeaveRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  decidedBy Employee?    @relation("LeaveApprovalDecider", fields: [decidedById], references: [id])

  @@unique([requestId, round, stepOrder])
  @@index([requestId])
  @@index([tenantId])
  @@map("leave_approvals")
}

// Timeline lịch sử duyệt cho mỗi OvertimeRequest. Snapshot từ ApprovalStep tại
// thời điểm nộp; mỗi lần đơn bị trả về rồi nộp lại sinh round mới. Cấu trúc song
// song với LeaveApproval (OT có bảng riêng để cấu hình flow độc lập với Leave).
model OvertimeApproval {
  id                String            @id @default(cuid())
  tenantId          String            @map("tenant_id")
  overtimeRequestId String            @map("overtime_request_id")
  round             Int               @default(1) // tăng mỗi lần đơn bị trả về rồi nộp lại
  stepOrder         Int               @map("step_order")
  approverType      ApproverType      @map("approver_type")
  roleKey           String?           @map("role_key")
  approverId        String?           @map("approver_id") // người duyệt kỳ vọng (resolved); null nếu không xác định được
  decision          ApprovalDecision? // null = đang chờ (pending)
  decidedById       String?           @map("decided_by_id")
  decidedAt         DateTime?         @map("decided_at")
  note              String?
  createdAt         DateTime          @default(now()) @map("created_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  request   OvertimeRequest @relation(fields: [overtimeRequestId], references: [id], onDelete: Cascade)
  decidedBy Employee?       @relation("OvertimeApprovalDecider", fields: [decidedById], references: [id])

  @@unique([overtimeRequestId, round, stepOrder])
  @@index([overtimeRequestId])
  @@index([tenantId])
  @@map("overtime_approvals")
}

// SPEC-041: Yêu cầu thanh toán / hoàn ứng. NV tạo đơn kèm hoá đơn/bill, đi qua
// chuỗi duyệt cố định (NV → Quản lý → Founder) rồi được đánh dấu đã thanh toán.
// Tái dùng routing engine ApprovalFlow/ApprovalStep (flowType = PAYMENT).
model PaymentRequest {
  id          String               @id @default(cuid())
  tenantId    String               @map("tenant_id")
  employeeId  String               @map("employee_id") // người tạo đơn
  type        PaymentRequestType
  title       String
  description String?
  amount      Decimal              @db.Decimal(14, 2)
  currency    String               @default("VND")
  status      PaymentRequestStatus @default(PENDING)

  // field tuỳ-loại (nullable)
  expenseDate   DateTime? @map("expense_date") // REIMBURSEMENT: ngày đã chi
  category      String? // REIMBURSEMENT: phân loại chi
  neededByDate  DateTime? @map("needed_by_date") // ADVANCE: cần tiền trước ngày
  vendorName    String?   @map("vendor_name") // VENDOR_PAYMENT
  invoiceNumber String?   @map("invoice_number") // VENDOR_PAYMENT
  dueDate       DateTime? @map("due_date") // VENDOR_PAYMENT: hạn thanh toán

  // routing (tái dùng ApprovalFlow)
  flowId       String?   @map("flow_id")
  currentStep  Int       @default(0) @map("current_step") // 1-based step đang chờ; 0 = chưa vào flow
  reviewedById String?   @map("reviewed_by_id") // người duyệt cuối (tiện tra cứu)
  reviewedAt   DateTime? @map("reviewed_at")
  reviewNote   String?   @map("review_note")

  // thanh toán
  paidById    String?   @map("paid_by_id")
  paidAt      DateTime? @map("paid_at")
  paymentNote String?   @map("payment_note") // số tham chiếu / ngày chuyển khoản

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee    Employee                   @relation("EmployeePaymentRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy  Employee?                  @relation("PaymentRequestReviewer", fields: [reviewedById], references: [id])
  paidBy      Employee?                  @relation("PaymentRequestPayer", fields: [paidById], references: [id])
  flow        ApprovalFlow?              @relation(fields: [flowId], references: [id])
  approvals   PaymentRequestApproval[]
  attachments PaymentRequestAttachment[]

  @@index([tenantId, status])
  @@index([employeeId])
  @@index([flowId])
  @@map("payment_requests")
}

// SPEC-041: timeline lịch sử duyệt cho mỗi PaymentRequest. Snapshot từ ApprovalStep
// tại thời điểm nộp; mỗi lần đơn bị trả về rồi nộp lại sinh round mới. Song song với
// LeaveApproval/OvertimeApproval.
model PaymentRequestApproval {
  id           String            @id @default(cuid())
  tenantId     String            @map("tenant_id")
  requestId    String            @map("request_id")
  round        Int               @default(1) // tăng mỗi lần đơn bị trả về rồi nộp lại
  stepOrder    Int               @map("step_order")
  approverType ApproverType      @map("approver_type")
  roleKey      String?           @map("role_key")
  approverId   String?           @map("approver_id") // người duyệt kỳ vọng (resolved); null nếu không xác định được
  decision     ApprovalDecision? // null = đang chờ (pending)
  decidedById  String?           @map("decided_by_id")
  decidedAt    DateTime?         @map("decided_at")
  note         String?
  createdAt    DateTime          @default(now()) @map("created_at")

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  request   PaymentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  decidedBy Employee?      @relation("PaymentApprovalDecider", fields: [decidedById], references: [id])

  @@unique([requestId, round, stepOrder])
  @@index([requestId])
  @@index([tenantId])
  @@map("payment_request_approvals")
}

// SPEC-041: chứng từ đính kèm (hoá đơn đỏ / bill). Nhiều file/đơn. Lưu qua storage
// driver (local↔GCS), tải xuống qua API có kiểm soát quyền + tenant.
model PaymentRequestAttachment {
  id        String   @id @default(cuid())
  requestId String   @map("request_id")
  fileUrl   String   @map("file_url") // /uploads/payment/<uuid>.<ext>
  fileName  String   @map("file_name")
  mimeType  String   @map("mime_type")
  size      Int // bytes
  createdAt DateTime @default(now()) @map("created_at")

  request PaymentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("payment_request_attachments")
}

// SPEC-042: phiếu đề xuất mua hàng (Purchase Requisition). Mirror PaymentRequest
// nhưng có nhiều dòng hàng (PurchaseRequestItem), VAT theo dòng, mã phiếu tự sinh
// (PR-YYYYMMDD-NNN). Tổng tiền denormalized (server tính lại mỗi create/update).
enum PurchaseRequestStatus {
  PENDING
  APPROVED
  REJECTED // terminal — bị từ chối hẳn
  RETURNED // trả về để sửa & gửi lại (không terminal)
  CANCELLED
  ORDERED // terminal — đã phát hành PO cho nhà cung cấp
}

model PurchaseRequest {
  id                   String                @id @default(cuid())
  tenantId             String                @map("tenant_id")
  employeeId           String                @map("employee_id") // người tạo phiếu
  code                 String                @map("code") // PR-YYYYMMDD-NNN (tự sinh, unique theo tenant)
  title                String
  description          String?
  vendorName           String                @map("vendor_name") // nhà cung cấp (kính gửi)
  expectedDeliveryDate DateTime?             @map("expected_delivery_date")
  currency             String                @default("VND")
  status               PurchaseRequestStatus @default(PENDING)

  // tổng tiền (denormalized, server tính lại mỗi create/update)
  subtotal    Decimal @default(0) @db.Decimal(14, 2)
  taxAmount   Decimal @default(0) @map("tax_amount") @db.Decimal(14, 2)
  totalAmount Decimal @default(0) @map("total_amount") @db.Decimal(14, 2)

  // routing (tái dùng ApprovalFlow)
  flowId       String?   @map("flow_id")
  currentStep  Int       @default(0) @map("current_step") // 1-based step đang chờ; 0 = chưa vào flow
  reviewedById String?   @map("reviewed_by_id")
  reviewedAt   DateTime? @map("reviewed_at")
  reviewNote   String?   @map("review_note")

  // đặt hàng
  orderedById String?   @map("ordered_by_id")
  orderedAt   DateTime? @map("ordered_at")
  orderNote   String?   @map("order_note") // số PO / ghi chú đặt hàng

  // SPEC-043: pháp nhân phát hành (đơn vị đứng tên trên PO PDF). Snapshot trọn bộ
  // lúc tạo/sửa để PDF phiếu cũ không sai khi entity bị sửa/ẩn sau này. Tất cả
  // nullable → phiếu cũ / không chọn → PDF fallback settings.company.
  issuingEntityId    String? @map("issuing_entity_id")
  issuingCompanyName String? @map("issuing_company_name")
  issuingAddress     String? @map("issuing_address")
  issuingTaxCode     String? @map("issuing_tax_code")
  issuingPhone       String? @map("issuing_phone")
  issuingLogoUrl     String? @map("issuing_logo_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant        Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee      Employee                    @relation("EmployeePurchaseRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy    Employee?                   @relation("PurchaseRequestReviewer", fields: [reviewedById], references: [id])
  orderedBy     Employee?                   @relation("PurchaseRequestOrderer", fields: [orderedById], references: [id])
  flow          ApprovalFlow?               @relation(fields: [flowId], references: [id])
  issuingEntity IssuingEntity?              @relation(fields: [issuingEntityId], references: [id])
  items         PurchaseRequestItem[]
  approvals     PurchaseRequestApproval[]
  attachments   PurchaseRequestAttachment[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([employeeId])
  @@index([flowId])
  @@index([issuingEntityId])
  @@map("purchase_requests")
}

// SPEC-042: dòng hàng của phiếu. VAT tính theo từng dòng; các giá trị tiền
// (lineSubtotal/lineTax/lineTotal) server tính lại & lưu để export/PDF nhanh.
model PurchaseRequestItem {
  id           String  @id @default(cuid())
  requestId    String  @map("request_id")
  lineNo       Int     @map("line_no") // 1-based, thứ tự hiển thị
  sku          String? // mã SKU (tuỳ chọn)
  productName  String  @map("product_name")
  unit         String? // ĐVT: cái, bộ, kg...
  quantity     Decimal @db.Decimal(14, 3) // hỗ trợ số lẻ (kg, m3...)
  unitPrice    Decimal @map("unit_price") @db.Decimal(14, 2)
  taxRate      Decimal @default(8) @map("tax_rate") @db.Decimal(5, 2) // % VAT của dòng
  lineSubtotal Decimal @map("line_subtotal") @db.Decimal(14, 2) // quantity × unitPrice
  lineTax      Decimal @map("line_tax") @db.Decimal(14, 2) // lineSubtotal × taxRate/100
  lineTotal    Decimal @map("line_total") @db.Decimal(14, 2) // lineSubtotal + lineTax

  request PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("purchase_request_items")
}

// SPEC-043: pháp nhân phát hành (đơn vị đứng tên trên PO PDF). Master data theo
// tenant; phiếu PR chọn 1 entity và snapshot trọn bộ thông tin vào phiếu lúc
// tạo/sửa. Xoá mềm bằng `active=false`; chỉ 1 `isDefault` mỗi tenant (enforced
// trong service bằng transaction).
model IssuingEntity {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  address   String?
  taxCode   String?  @map("tax_code")
  phone     String?
  logoUrl   String?  @map("logo_url") // /uploads/entity-logo/<uuid>.<png|jpg>
  isDefault Boolean  @default(false) @map("is_default")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseRequests PurchaseRequest[]
  quotes           Quote[] // SPEC-045: báo giá xuất theo pháp nhân
  fundAccounts     FundAccount[] // SPEC-048
  cashTransactions CashTransaction[] // SPEC-048
  spendingPlans    SpendingPlan[] // SPEC-048 GĐ2
  topUpRequests    TopUpRequest[] // SPEC-048 GĐ3

  @@index([tenantId])
  @@map("issuing_entities")
}

// SPEC-042: timeline lịch sử duyệt cho mỗi PurchaseRequest (song song với
// PaymentRequestApproval). Snapshot bước tại thời điểm nộp; mỗi vòng = 1 round.
model PurchaseRequestApproval {
  id           String            @id @default(cuid())
  tenantId     String            @map("tenant_id")
  requestId    String            @map("request_id")
  round        Int               @default(1) // tăng mỗi lần đơn bị trả về rồi nộp lại
  stepOrder    Int               @map("step_order")
  approverType ApproverType      @map("approver_type")
  roleKey      String?           @map("role_key")
  approverId   String?           @map("approver_id") // người duyệt kỳ vọng (resolved); null nếu không xác định được
  decision     ApprovalDecision? // null = đang chờ (pending)
  decidedById  String?           @map("decided_by_id")
  decidedAt    DateTime?         @map("decided_at")
  note         String?
  createdAt    DateTime          @default(now()) @map("created_at")

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  request   PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  decidedBy Employee?       @relation("PurchaseApprovalDecider", fields: [decidedById], references: [id])

  @@unique([requestId, round, stepOrder])
  @@index([requestId])
  @@index([tenantId])
  @@map("purchase_request_approvals")
}

// SPEC-042: chứng từ đính kèm (báo giá / hợp đồng / hình mẫu). Nhiều file/phiếu.
model PurchaseRequestAttachment {
  id        String   @id @default(cuid())
  requestId String   @map("request_id")
  fileUrl   String   @map("file_url") // /uploads/purchase/<uuid>.<ext>
  fileName  String   @map("file_name")
  mimeType  String   @map("mime_type")
  size      Int // bytes
  createdAt DateTime @default(now()) @map("created_at")

  request PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("purchase_request_attachments")
}

// Per-tenant timesheet/overtime policy. Defines what "a working day" and
// "overtime" mean for the tenant. Auto-seeded with VN defaults on first read.
// Multipliers are snapshotted onto each OvertimeRequest at approval, so editing
// this policy never retro-changes already-approved (locked) overtime pay.
model TimesheetPolicy {
  id                  String   @id @default(cuid())
  tenantId            String   @unique @map("tenant_id")
  // 0=Sunday .. 6=Saturday (JS getDay convention). Default Mon–Fri.
  workdays            Int[]    @default([1, 2, 3, 4, 5])
  standardHoursPerDay Float    @default(8) @map("standard_hours_per_day")
  nightStart          String   @default("22:00") @map("night_start") // HH:mm, per BLLĐ
  nightEnd            String   @default("06:00") @map("night_end")
  otWeekday           Float    @default(1.5) @map("ot_weekday")
  otWeekend           Float    @default(2.0) @map("ot_weekend")
  otHoliday           Float    @default(3.0) @map("ot_holiday")
  nightExtra          Float    @default(0.3) @map("night_extra")
  nightOtExtra        Float    @default(0.2) @map("night_ot_extra")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("timesheet_policies")
}

// Per-tenant holiday calendar. A holiday date overrides weekday/weekend
// classification when deriving the overtime category. `recurring` marks
// fixed-date annual holidays (e.g. 30/4, 1/5, 2/9); lunar dates are seeded as
// concrete dates for the current year and edited manually.
model Holiday {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  date      DateTime @db.Date
  name      String
  recurring Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date])
  @@index([tenantId])
  @@map("holidays")
}

// One attendance record per employee per work date. Check-in creates the
// record; check-out updates the same one. `workedHours` is computed server-side
// from check-in/out. Reviewer corrections set source=MANUAL_ADJUST + adjustedById.
model AttendanceRecord {
  id           String           @id @default(cuid())
  tenantId     String           @map("tenant_id")
  employeeId   String           @map("employee_id")
  workDate     DateTime         @map("work_date") @db.Date
  checkInAt    DateTime?        @map("check_in_at")
  checkOutAt   DateTime?        @map("check_out_at")
  note         String?
  workedHours  Float?           @map("worked_hours")
  source       AttendanceSource @default(SELF)
  adjustedById String?          @map("adjusted_by_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   Employee  @relation("EmployeeAttendance", fields: [employeeId], references: [id], onDelete: Cascade)
  adjustedBy Employee? @relation("AttendanceAdjuster", fields: [adjustedById], references: [id])

  @@unique([tenantId, employeeId, workDate])
  @@index([tenantId, employeeId])
  @@index([adjustedById])
  @@map("attendance_records")
}

// Overtime request. `category` is derived server-side from the work date vs
// policy workdays + holiday calendar. `multiplier` is null until approval, when
// the effective rate is snapshotted (immutable for payroll).
model OvertimeRequest {
  id           String           @id @default(cuid())
  tenantId     String           @map("tenant_id")
  employeeId   String           @map("employee_id")
  workDate     DateTime         @map("work_date") @db.Date
  hours        Float
  night        Boolean          @default(false)
  category     OvertimeCategory
  reason       String?
  status       OvertimeStatus   @default(PENDING)
  flowId       String?          @map("flow_id")
  currentStep  Int              @default(0) @map("current_step") // 1-based step đang chờ; 0 = legacy/đã kết thúc
  multiplier   Float? // snapshotted effective multiplier at approval
  reviewedById String?          @map("reviewed_by_id")
  reviewedAt   DateTime?        @map("reviewed_at")
  reviewNote   String?          @map("review_note")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee   Employee           @relation("EmployeeOvertime", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy Employee?          @relation("OvertimeReviewer", fields: [reviewedById], references: [id])
  flow       ApprovalFlow?      @relation(fields: [flowId], references: [id])
  approvals  OvertimeApproval[]

  @@index([tenantId, status])
  @@index([tenantId, employeeId])
  @@index([reviewedById])
  @@index([flowId])
  @@map("overtime_requests")
}

// Per-tenant payroll configuration. One row per tenant, auto-seeded with VN
// defaults on first access. Every statutory value is a config field (never
// hardcoded). The settings used by a run are snapshotted onto the run, so
// editing this row never retro-changes an already-approved period.
model PayrollSettings {
  id                        String        @id @default(cuid())
  tenantId                  String        @unique @map("tenant_id")
  currency                  String        @default("VND")
  payDay                    Int           @default(5) @map("pay_day") // day-of-month, informational
  socialInsuranceRate       Float         @default(0.08) @map("social_insurance_rate") // BHXH (employee-side)
  healthInsuranceRate       Float         @default(0.015) @map("health_insurance_rate") // BHYT
  unemploymentInsuranceRate Float         @default(0.01) @map("unemployment_insurance_rate") // BHTN
  // Phí công đoàn (đoàn phí) — employee-side fraction on the same insurance base.
  // Post-tax: reduces net pay but is NOT deducted from taxable income. Default 0
  // so existing tenants are unaffected until they opt in via settings.
  unionFeeRate              Float         @default(0) @map("union_fee_rate")
  insuranceBase             InsuranceBase @default(BASE_SALARY) @map("insurance_base")
  insuranceCap              Decimal?      @map("insurance_cap") @db.Decimal(15, 2)
  personalDeduction         Decimal       @default(11000000) @map("personal_deduction") @db.Decimal(15, 2)
  dependentDeduction        Decimal       @default(4400000) @map("dependent_deduction") @db.Decimal(15, 2)
  // Ordered progressive PIT table: [{ upTo: number|null, rate: number }];
  // null upTo = top bracket. Default = the 7-step VN table (seeded in code).
  taxBrackets               Json          @map("tax_brackets")
  createdAt                 DateTime      @default(now()) @map("created_at")
  updatedAt                 DateTime      @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payroll_settings")
}

// Effective-dated salary history. Setting a new salary closes the previous
// record (effectiveTo); only one record is in force per employee per date. A
// pay run for month M resolves the salary in force on M. Records are never
// hard-overwritten — raises stay auditable.
model EmployeeSalary {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  employeeId    String    @map("employee_id")
  baseSalary    Decimal   @map("base_salary") @db.Decimal(15, 2)
  // Named allowances: [{ name: string, amount: number, taxable: boolean }].
  allowances    Json      @default("[]")
  effectiveFrom DateTime  @map("effective_from") @db.Date
  effectiveTo   DateTime? @map("effective_to") @db.Date // null = currently in force
  note          String?
  createdById   String?   @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee  Employee  @relation("EmployeeSalaries", fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy Employee? @relation("SalaryCreator", fields: [createdById], references: [id])

  @@index([tenantId, employeeId, effectiveFrom])
  @@index([employeeId])
  @@map("employee_salaries")
}

// A per-tenant, per-month batch. HR computes (DRAFT), reviews, approves
// (locks + snapshots), and marks paid. `settingsSnapshot` freezes the payroll
// settings used so an approved/paid period is fully reproducible. Totals are
// the sum of its payslip lines.
model PayrollRun {
  id               String           @id @default(cuid())
  tenantId         String           @map("tenant_id")
  period           String // "YYYY-MM"
  status           PayrollRunStatus @default(DRAFT)
  settingsSnapshot Json?            @map("settings_snapshot") // frozen at approval
  headcount        Int              @default(0)
  totalGross       Decimal          @default(0) @map("total_gross") @db.Decimal(15, 2)
  totalDeductions  Decimal          @default(0) @map("total_deductions") @db.Decimal(15, 2)
  totalNet         Decimal          @default(0) @map("total_net") @db.Decimal(15, 2)
  runById          String?          @map("run_by_id")
  submittedById    String?          @map("submitted_by_id")
  submittedAt      DateTime?        @map("submitted_at")
  approvedById     String?          @map("approved_by_id")
  approvedAt       DateTime?        @map("approved_at")
  paidAt           DateTime?        @map("paid_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payslips Payslip[]

  @@unique([tenantId, period])
  @@index([tenantId, status])
  @@map("payroll_runs")
}

// One payslip line per employee per run. Snapshots all inputs (salary,
// timesheet summary figures, dependents) AND every computed intermediate
// figure, so the breakdown is transparent and an approved line is immutable
// regardless of later upstream changes. Money is Decimal(15,2), whole VND.
model Payslip {
  id           String @id @default(cuid())
  tenantId     String @map("tenant_id")
  payrollRunId String @map("payroll_run_id")
  employeeId   String @map("employee_id")

  // ── snapshotted inputs ──
  baseSalary      Decimal @map("base_salary") @db.Decimal(15, 2)
  allowances      Json    @default("[]")
  dependents      Int     @default(0)
  workingDays     Int     @map("working_days")
  daysPresent     Int     @map("days_present")
  paidLeaveDays   Float   @default(0) @map("paid_leave_days")
  unpaidLeaveDays Float   @default(0) @map("unpaid_leave_days")
  daysAbsent      Float   @default(0) @map("days_absent")
  holidayCount    Int     @default(0) @map("holiday_count")
  // [{ category, night, hours, multiplier, amount }]
  overtime        Json    @default("[]")

  // ── computed breakdown ──
  proratedBase          Decimal @map("prorated_base") @db.Decimal(15, 2)
  allowanceTotal        Decimal @map("allowance_total") @db.Decimal(15, 2)
  otPay                 Decimal @map("ot_pay") @db.Decimal(15, 2)
  grossPay              Decimal @map("gross_pay") @db.Decimal(15, 2)
  socialInsurance       Decimal @map("social_insurance") @db.Decimal(15, 2)
  healthInsurance       Decimal @map("health_insurance") @db.Decimal(15, 2)
  unemploymentInsurance Decimal @map("unemployment_insurance") @db.Decimal(15, 2)
  insuranceTotal        Decimal @map("insurance_total") @db.Decimal(15, 2)
  taxableIncome         Decimal @map("taxable_income") @db.Decimal(15, 2)
  personalIncomeTax     Decimal @map("personal_income_tax") @db.Decimal(15, 2)
  unionFee              Decimal @default(0) @map("union_fee") @db.Decimal(15, 2)
  otherDeductions       Decimal @default(0) @map("other_deductions") @db.Decimal(15, 2)
  netPay                Decimal @map("net_pay") @db.Decimal(15, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation("EmployeePayslips", fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@index([tenantId, employeeId])
  @@map("payslips")
}

// Employment contract history. An employee may have several contracts over
// time, but at most ONE with status ACTIVE (enforced transactionally in the
// service). `endDate = null` means an indefinite-term contract, which never
// produces an expiry reminder. The [tenantId, status, endDate] index backs the
// daily reminder scan (find ACTIVE contracts expiring within the window).
model Contract {
  id         String         @id @default(cuid())
  tenantId   String         @map("tenant_id")
  employeeId String         @map("employee_id")
  type       ContractType
  startDate  DateTime       @map("start_date")
  endDate    DateTime?      @map("end_date") // null = không xác định thời hạn
  status     ContractStatus @default(ACTIVE)
  signedAt   DateTime?      @map("signed_at")
  note       String?
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation("EmployeeContracts", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
  @@index([tenantId, status, endDate])
  @@map("contracts")
}

// Bộ tiêu chí đánh giá thử việc, cấu hình theo tenant (SPEC-030). Tiêu chí đã được
// review tham chiếu không xóa cứng được — chỉ deactivate (isActive=false) để giữ
// nguyện dữ liệu lịch sử mà ratings JSON trên ProbationReview trỏ tới theo id.
model ProbationCriteria {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  order     Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  // SPEC-031: tách What/How — 'PERFORMANCE' | 'VALUES' (String + default để dễ mở rộng).
  group     String   @default("PERFORMANCE")
  // SPEC-031: rubric BARS [{ score:1..5, level, definition?, observable? }]; null = không hướng dẫn.
  rubric    Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@map("probation_criteria")
}

// Đánh giá thử việc (SPEC-030). Luồng 2 bên cố định: MANAGER đánh giá scorecard +
// đề xuất (DRAFT→PENDING_HR), HR ra quyết định cuối (→DECIDED) với hệ quả tự động.
// `ratings` là JSON { [criteriaId]: 1..5 }. Tối đa 1 review mở (DRAFT|PENDING_HR)
// mỗi nhân viên (enforce ở service).
model ProbationReview {
  id         String                @id @default(cuid())
  tenantId   String                @map("tenant_id")
  employeeId String                @map("employee_id")
  status     ProbationReviewStatus @default(DRAFT)

  // SPEC-033: Step 1 — nhân viên tự đánh giá (song song khi DRAFT, khóa sau khi nộp
  // hoặc khi review rời DRAFT). selfSubmittedAt null = chưa nộp.
  selfRatings     Json?     @map("self_ratings") // { [criteriaId]: 1..5 }
  selfComment     String?   @map("self_comment") @db.Text
  selfSubmittedAt DateTime? @map("self_submitted_at")

  // Manager đánh giá (scorecard)
  reviewerId     String?           @map("reviewer_id")
  ratings        Json? // { [criteriaId]: 1..5 }
  // SPEC-031: nhật ký bằng chứng deliverable [{ title, link?, outcome?, note? }]; null = chưa nhập.
  deliverables   Json?
  strengths      String?
  weaknesses     String?
  comment        String?
  recommendation ProbationOutcome?
  submittedAt    DateTime?         @map("submitted_at")

  // HR quyết định
  decidedById         String?           @map("decided_by_id")
  decision            ProbationOutcome?
  decisionNote        String?           @map("decision_note")
  decidedAt           DateTime?         @map("decided_at")
  newProbationEndDate DateTime?         @map("new_probation_end_date") // chỉ khi EXTEND

  // snapshot ngày hết TV tại lúc tạo (hiển thị/audit)
  probationEndDateAtCreate DateTime? @map("probation_end_date_at_create")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee  Employee  @relation("EmployeeProbationReviews", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer  Employee? @relation("ProbationReviewer", fields: [reviewerId], references: [id])
  decidedBy Employee? @relation("ProbationDecider", fields: [decidedById], references: [id])

  @@index([tenantId, status])
  @@index([employeeId])
  @@map("probation_reviews")
}

// SPEC-032: bài hướng dẫn đánh giá thử việc cho manager, HR soạn theo năm áp dụng.
// Một năm có thể có nhiều bài; xem cần probation:view, ghi cần probation:configure.
model ProbationGuideline {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  year      Int
  // 'vi' | 'en' — tab Hướng dẫn lọc theo ngôn ngữ UI đang chọn (SPEC-032 §2c).
  language  String   @default("vi")
  title     String
  content   String   @db.Text
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, year])
  @@map("probation_guidelines")
}

// Loại tài sản, cấu hình theo từng tenant (Laptop, Chuột, Bàn ghế…).
model AssetCategory {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  code        String // mã ngắn, ví dụ "LAPTOP"
  description String?
  icon        String? // tên Lucide icon (tùy chọn)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assets Asset[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("asset_categories")
}

model Asset {
  id               String          @id @default(cuid())
  tenantId         String          @map("tenant_id")
  categoryId       String          @map("category_id")
  assetCode        String          @map("asset_code")
  name             String
  serialNumber     String?         @map("serial_number")
  brand            String?
  model            String?
  status           AssetStatus     @default(AVAILABLE)
  condition        AssetCondition?
  purchaseDate     DateTime?       @map("purchase_date")
  purchaseCost     Decimal?        @map("purchase_cost") @db.Decimal(14, 2) // tham chiếu (VND)
  warrantyEndDate  DateTime?       @map("warranty_end_date")
  vendor           String?
  location         String?
  note             String?
  retiredAt        DateTime?       @map("retired_at")
  retirementReason String?         @map("retirement_reason")
  retiredById      String?         @map("retired_by_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category     AssetCategory      @relation(fields: [categoryId], references: [id])
  assignments  AssetAssignment[]
  maintenances AssetMaintenance[]

  @@unique([tenantId, assetCode])
  @@index([tenantId, status])
  @@index([categoryId])
  @@map("assets")
}

model AssetAssignment {
  id                   String                @id @default(cuid())
  tenantId             String                @map("tenant_id")
  assetId              String                @map("asset_id")
  employeeId           String                @map("employee_id")
  status               AssetAssignmentStatus @default(ACTIVE)
  assignedAt           DateTime              @map("assigned_at")
  assignedById         String                @map("assigned_by_id")
  conditionOut         AssetCondition?       @map("condition_out")
  returnedAt           DateTime?             @map("returned_at")
  returnedById         String?               @map("returned_by_id")
  conditionIn          AssetCondition?       @map("condition_in")
  note                 String?
  // Handover acknowledgement (biên bản bàn giao). signatureImage is a PNG data
  // URL — personal data, never logged and never returned in list endpoints.
  ackStatus            AssetAckStatus        @default(PENDING) @map("ack_status")
  ackMethod            AssetAckMethod?       @map("ack_method")
  acknowledgedAt       DateTime?             @map("acknowledged_at")
  acknowledgedByUserId String?               @map("acknowledged_by_user_id")
  signatureImage       String?               @map("signature_image") @db.Text
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee   Employee  @relation("AssetHolder", fields: [employeeId], references: [id])
  assignedBy Employee  @relation("AssetAssigner", fields: [assignedById], references: [id])
  returnedBy Employee? @relation("AssetReturner", fields: [returnedById], references: [id])

  @@index([tenantId, assetId])
  @@index([tenantId, employeeId, status])
  @@index([tenantId, ackStatus])
  @@map("asset_assignments")
}

model AssetMaintenance {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  assetId     String    @map("asset_id")
  startedAt   DateTime  @map("started_at")
  completedAt DateTime? @map("completed_at")
  cost        Decimal?  @db.Decimal(14, 2)
  vendor      String?
  description String
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy Employee @relation("MaintenanceCreator", fields: [createdById], references: [id])

  @@index([tenantId, assetId])
  @@map("asset_maintenances")
}

// In-app notification addressed to a single recipient (userId). The daily
// reminder scan is idempotent via @@unique([userId, dedupeKey]): re-running the
// scan on the same day cannot create a duplicate row. `dedupeKey` embeds the due
// date (e.g. 'probation_ending:{empId}:{YYYY-MM-DD}') so moving a date produces
// a fresh reminder for the new milestone without resending the old one.
model Notification {
  id         String    @id @default(cuid())
  tenantId   String    @map("tenant_id")
  userId     String    @map("user_id")
  kind       String
  title      String
  body       String
  entityType String?   @map("entity_type")
  entityId   String?   @map("entity_id")
  dedupeKey  String    @map("dedupe_key")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([tenantId, userId, readAt])
  @@map("notifications")
}

// ===== Recruitment / ATS (SPEC-024) =====

// Pipeline template (cấp tenant) — nguồn để clone JobStage khi tạo Job.
model PipelineTemplate {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages PipelineTemplateStage[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("pipeline_templates")
}

model PipelineTemplateStage {
  id         String    @id @default(cuid())
  templateId String    @map("template_id")
  name       String
  order      Int
  type       StageType

  template PipelineTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, order])
  @@map("pipeline_template_stages")
}

// Job (requisition + posting gộp cho MVP).
model Job {
  id             String            @id @default(cuid())
  tenantId       String            @map("tenant_id")
  departmentId   String?           @map("department_id")
  positionId     String?           @map("position_id")
  title          String
  description    String?
  employmentType JobEmploymentType @default(FULL_TIME) @map("employment_type")
  location       String?
  headcount      Int               @default(1)
  status         JobStatus         @default(DRAFT)
  createdById    String            @map("created_by_id")
  openedAt       DateTime?         @map("opened_at")
  closedAt       DateTime?         @map("closed_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  position   Position?   @relation(fields: [positionId], references: [id])
  createdBy  Employee    @relation("JobCreator", fields: [createdById], references: [id])

  stages            JobStage[]
  applications      Application[]
  hiringTeam        JobHiringTeam[]
  bulkImportBatches BulkImportBatch[]

  @@index([tenantId, status])
  @@index([departmentId])
  @@index([positionId])
  @@map("jobs")
}

// Stage thuộc 1 Job (clone từ template khi tạo Job).
model JobStage {
  id    String    @id @default(cuid())
  jobId String    @map("job_id")
  name  String
  order Int
  type  StageType

  job          Job                       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applications Application[]
  fromHistory  ApplicationStageHistory[] @relation("FromStage")
  toHistory    ApplicationStageHistory[] @relation("ToStage")

  @@unique([jobId, order])
  @@index([jobId])
  @@map("job_stages")
}

model JobHiringTeam {
  id         String         @id @default(cuid())
  jobId      String         @map("job_id")
  employeeId String         @map("employee_id")
  teamRole   HiringTeamRole @map("team_role")

  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  employee Employee @relation("HiringTeamMember", fields: [employeeId], references: [id])

  @@unique([jobId, employeeId])
  @@index([employeeId])
  @@map("job_hiring_team")
}

// Candidate (con người, chống trùng, PDPL).
model Candidate {
  id             String          @id @default(cuid())
  tenantId       String          @map("tenant_id")
  fullName       String          @map("full_name")
  email          String?
  phone          String? // chuẩn hóa E.164 để dedupe
  location       String?
  currentTitle   String?         @map("current_title")
  totalYearsExp  Float?          @map("total_years_exp")
  source         CandidateSource @default(DIRECT)
  links          Json? // {linkedin, github, portfolio}
  avatar         String?
  dateOfBirth    DateTime?       @map("date_of_birth")
  gender         Gender?
  skills         String[] // denormalize để filter nhanh
  rawCvText      String?         @map("raw_cv_text") // full-text search
  // PDPL
  consentGivenAt DateTime?       @map("consent_given_at")
  consentSource  String?         @map("consent_source")
  retentionUntil DateTime?       @map("retention_until")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attachments  CandidateAttachment[]
  applications Application[]

  // email nullable — dedupe (email→phone→fuzzy) enforce ở service layer.
  @@unique([tenantId, email])
  @@index([tenantId, phone])
  @@map("candidates")
}

model CandidateAttachment {
  id             String         @id @default(cuid())
  candidateId    String         @map("candidate_id")
  kind           AttachmentKind @default(CV)
  fileUrl        String         @map("file_url")
  fileName       String         @map("file_name")
  parseStatus    ParseStatus    @default(PENDING) @map("parse_status")
  parserProvider String?        @map("parser_provider")
  parsedData     Json?          @map("parsed_data")
  parsedAt       DateTime?      @map("parsed_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("candidate_attachments")
}

// Application (junction Candidate × Job).
model Application {
  id              String            @id @default(cuid())
  tenantId        String            @map("tenant_id")
  candidateId     String            @map("candidate_id")
  jobId           String            @map("job_id")
  currentStageId  String            @map("current_stage_id")
  status          ApplicationStatus @default(ACTIVE)
  source          CandidateSource   @default(DIRECT)
  rejectionReason RejectionReason?  @map("rejection_reason")
  appliedAt       DateTime          @default(now()) @map("applied_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  currentStage JobStage  @relation(fields: [currentStageId], references: [id])

  stageHistory ApplicationStageHistory[]
  interviews   Interview[]
  activities   ApplicationActivity[]

  // 1 active application / (candidate, job) — enforce ở service layer.
  @@index([tenantId, jobId, currentStageId])
  @@index([candidateId])
  @@map("applications")
}

// ⭐ Lịch sử chuyển stage — nền tảng analytics velocity/conversion (build NGAY).
model ApplicationStageHistory {
  id            String   @id @default(cuid())
  applicationId String   @map("application_id")
  fromStageId   String?  @map("from_stage_id")
  toStageId     String   @map("to_stage_id")
  changedById   String   @map("changed_by_id")
  note          String?
  changedAt     DateTime @default(now()) @map("changed_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStage   JobStage?   @relation("FromStage", fields: [fromStageId], references: [id])
  toStage     JobStage    @relation("ToStage", fields: [toStageId], references: [id])
  changedBy   Employee    @relation("StageChanger", fields: [changedById], references: [id])

  @@index([applicationId])
  @@map("application_stage_history")
}

// Interview & Scorecard.
model Interview {
  id            String          @id @default(cuid())
  tenantId      String          @map("tenant_id")
  applicationId String          @map("application_id")
  stageId       String?         @map("stage_id")
  scheduledAt   DateTime        @map("scheduled_at")
  durationMin   Int             @default(60) @map("duration_min")
  mode          InterviewMode   @default(ONSITE)
  location      String?
  meetingUrl    String?         @map("meeting_url")
  status        InterviewStatus @default(SCHEDULED)
  createdById   String          @map("created_by_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdBy   Employee    @relation("InterviewCreator", fields: [createdById], references: [id])

  interviewers InterviewInterviewer[]
  scorecards   Scorecard[]

  @@index([tenantId, scheduledAt])
  @@index([applicationId])
  @@map("interviews")
}

model InterviewInterviewer {
  interviewId String @map("interview_id")
  employeeId  String @map("employee_id")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  employee  Employee  @relation("InterviewerAssignment", fields: [employeeId], references: [id])

  @@id([interviewId, employeeId])
  @@index([employeeId])
  @@map("interview_interviewers")
}

model Scorecard {
  id            String           @id @default(cuid())
  interviewId   String           @map("interview_id")
  interviewerId String           @map("interviewer_id")
  overall       ScorecardOverall
  ratings       Json? // {criterion: 1..4}
  notes         String?
  submittedAt   DateTime?        @map("submitted_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewer Employee  @relation("ScorecardInterviewer", fields: [interviewerId], references: [id])

  @@unique([interviewId, interviewerId])
  @@index([interviewerId])
  @@map("scorecards")
}

// Notes / activity feed.
model ApplicationActivity {
  id            String   @id @default(cuid())
  applicationId String   @map("application_id")
  authorId      String?  @map("author_id") // null = hệ thống
  type          String // "NOTE" | "STAGE_CHANGED" | "INTERVIEW_SCHEDULED" ...
  body          String?
  createdAt     DateTime @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  author      Employee?   @relation("ActivityAuthor", fields: [authorId], references: [id])

  @@index([applicationId])
  @@map("application_activities")
}

// Bulk CV intake (SPEC-027) — bảng staging. 1 batch = 1 lần upload nhiều CV vào 1 job.
model BulkImportBatch {
  id          String           @id @default(cuid())
  tenantId    String           @map("tenant_id")
  jobId       String           @map("job_id")
  createdById String           @map("created_by_id")
  status      BulkImportStatus @default(DRAFT)
  totalItems  Int              @default(0) @map("total_items")
  createdAt   DateTime         @default(now()) @map("created_at")
  confirmedAt DateTime?        @map("confirmed_at")

  job   Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  items BulkImportItem[]

  @@index([tenantId, jobId])
  @@map("bulk_import_batches")
}

// 1 item = 1 CV trong batch. parsedData = output parser; reviewedData = sau khi HR sửa.
model BulkImportItem {
  id                     String                   @id @default(cuid())
  batchId                String                   @map("batch_id")
  status                 BulkImportItemStatus     @default(PARSING)
  resolution             BulkImportItemResolution @default(NEW)
  fileUrl                String                   @map("file_url")
  fileName               String                   @map("file_name")
  mimeType               String                   @map("mime_type")
  rawCvText              String?                  @map("raw_cv_text") @db.Text
  parseStatus            ParseStatus              @default(PENDING) @map("parse_status")
  parserProvider         String?                  @map("parser_provider")
  parsedData             Json?                    @map("parsed_data")
  reviewedData           Json?                    @map("reviewed_data")
  duplicateOfCandidateId String?                  @map("duplicate_of_candidate_id")
  duplicateReason        String?                  @map("duplicate_reason")
  candidateId            String?                  @map("candidate_id")
  applicationId          String?                  @map("application_id")
  failureReason          String?                  @map("failure_reason")
  createdAt              DateTime                 @default(now()) @map("created_at")

  batch BulkImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@map("bulk_import_items")
}

/// Staged bulk-import rows held between /validate and /import. Replaces Redis
/// staging. Lazily expired on read; expired rows purged by the daily scan.
model ImportStaging {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  kind      String // 'employee' | 'asset'
  payload   Json
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("import_staging")
}

/// Background employee-import job status. Replaces BullMQ job state/progress/
/// returnvalue (which lived in Redis) for the import wizard's polling endpoint.
model ImportJob {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  state     String   @default("waiting") // waiting | active | completed | failed
  progress  Json? // { done: number, total: number }
  result    Json? // ImportJobResult
  error     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("import_job")
}

// ============================================================================
// SPEC-044: KPI / Performance Management Engine
// Engine cấu hình được: framework (bó KPI) → pillar (trụ cột) → definition (chỉ
// số). Framework "Agile Software Team" được seed sẵn như 1 template; mọi phòng
// ban tự định nghĩa framework riêng. Tracking mirror pattern PayrollRun→Payslip.
// ============================================================================

enum KpiDirection {
  HIGHER_BETTER // giá trị cao = tốt (velocity, coverage…)
  LOWER_BETTER // giá trị thấp = tốt (defect density, escaped, rework…)
}

enum KpiScope {
  INDIVIDUAL // chấm cho từng nhân viên (doanh số, learning hours…)
  TEAM // chấm 1 lần ở cấp squad, chia sẻ xuống mọi thành viên (velocity, CI/CD…)
}

enum KpiInputType {
  MANUAL // quản lý nhập số liệu thực tế
  SURVEY // lấy từ aggregate survey ẩn danh (Team Health)
}

enum KpiScoringMethod {
  THRESHOLD_LINEAR // quy đổi tuyến tính theo target/min (mặc định)
  DIRECT // actualValue đã là điểm 0..100
  BOOLEAN // đạt/không = 100/0
  BANDED // ánh xạ khoảng → điểm theo bảng cấu hình
}

enum KpiPeriodType {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum KpiCycleStatus {
  DRAFT // mới tạo, chưa mở nhập liệu
  DATA_ENTRY // đang nhập số liệu thực tế
  SELF_ASSESSMENT // nhân viên tự đánh giá
  PENDING_REVIEW // chờ quản lý/HR review + calibrate
  FINALIZED // đã chốt, scorecard bất biến
  CLOSED // đóng kỳ (lưu trữ)
}

enum KpiScorecardStatus {
  PENDING // chưa nhập đủ
  SELF_ASSESSED // nhân viên đã tự đánh giá
  IN_REVIEW // đang trong chuỗi duyệt
  FINALIZED // đã chốt
}

enum KpiSurveyType {
  MONTHLY_MORALE // 3 câu, 1-10, ẩn danh hàng tháng
  QUARTERLY_PEER_360 // 5 câu, 1-5, 360° peer review hàng quý
}

// Squad/team trong một phòng ban. KPI scope=TEAM chấm theo đơn vị này.
model Team {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  departmentId String?  @map("department_id")
  name         String
  leadId       String?  @map("lead_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  lead       Employee?   @relation("TeamLead", fields: [leadId], references: [id])
  members    Employee[]  @relation("TeamMembers")
  kpiEntries KpiEntry[] // SPEC-044 F2

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([departmentId])
  @@map("teams")
}

// Bó KPI có tên ("Agile Software Team", "Sales Performance"). passAnchor/
// targetAnchor là 2 mốc neo cho engine quy đổi điểm (60="Đạt", 90="Tốt").
model KpiFramework {
  id                String        @id @default(cuid())
  tenantId          String        @map("tenant_id")
  name              String
  description       String?
  defaultPeriodType KpiPeriodType @default(MONTHLY) @map("default_period_type")
  passAnchor        Decimal       @default(60) @map("pass_anchor") @db.Decimal(5, 2)
  targetAnchor      Decimal       @default(90) @map("target_anchor") @db.Decimal(5, 2)
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  tenant         Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pillars        KpiPillar[]
  weightProfiles KpiWeightProfile[]
  ratingBands    KpiRatingBand[]
  assignments    KpiFrameworkAssignment[]
  cycles         KpiCycle[]
  surveys        KpiSurvey[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("kpi_frameworks")
}

// Trụ cột (Delivery/Quality/Process/Team Health…). Σ weight các pillar = 100%.
model KpiPillar {
  id          String   @id @default(cuid())
  frameworkId String   @map("framework_id")
  name        String
  weight      Decimal  @db.Decimal(5, 2) // % trong tổng framework
  order       Int      @default(0)
  color       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  framework      KpiFramework             @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  definitions    KpiDefinition[]
  profileWeights KpiProfilePillarWeight[]
  scorecardRows  KpiScorecardPillar[]

  @@unique([frameworkId, name])
  @@index([frameworkId])
  @@map("kpi_pillars")
}

// Chỉ số KPI. Σ weightInPillar trong cùng 1 pillar = 100%.
model KpiDefinition {
  id             String           @id @default(cuid())
  pillarId       String           @map("pillar_id")
  code           String // D1, Q1, P1, T1…
  name           String
  description    String? // định nghĩa & cách tính
  dataSource     String?          @map("data_source")
  unit           String? // %, stories/sprint, bugs/SP, 1-10, hours…
  direction      KpiDirection     @default(HIGHER_BETTER)
  targetValue    Decimal?         @map("target_value") @db.Decimal(14, 4) // mốc "Tốt"
  minValue       Decimal?         @map("min_value") @db.Decimal(14, 4) // mốc "Đạt"
  weightInPillar Decimal          @default(0) @map("weight_in_pillar") @db.Decimal(5, 2)
  scope          KpiScope         @default(INDIVIDUAL)
  inputType      KpiInputType     @default(MANUAL)
  scoringMethod  KpiScoringMethod @default(THRESHOLD_LINEAR) @map("scoring_method")
  surveyKpiCode  String?          @map("survey_kpi_code") // khi inputType=SURVEY: khớp question.mapsToKpiCode
  frequency      String? // sprint/weekly/monthly/quarterly (thông tin)
  order          Int              @default(0)
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  pillar  KpiPillar  @relation(fields: [pillarId], references: [id], onDelete: Cascade)
  entries KpiEntry[]

  @@unique([pillarId, code])
  @@index([pillarId])
  @@map("kpi_definitions")
}

// Bộ trọng số trụ cột theo role (Dev 40/30/20/10, QA 25/45/20/10…). Σ = 100%.
model KpiWeightProfile {
  id          String   @id @default(cuid())
  frameworkId String   @map("framework_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  framework     KpiFramework             @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  pillarWeights KpiProfilePillarWeight[]

  @@unique([frameworkId, name])
  @@index([frameworkId])
  @@map("kpi_weight_profiles")
}

model KpiProfilePillarWeight {
  id        String  @id @default(cuid())
  profileId String  @map("profile_id")
  pillarId  String  @map("pillar_id")
  weight    Decimal @db.Decimal(5, 2)

  profile KpiWeightProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  pillar  KpiPillar        @relation(fields: [pillarId], references: [id], onDelete: Cascade)

  @@unique([profileId, pillarId])
  @@index([pillarId])
  @@map("kpi_profile_pillar_weights")
}

// Thang điểm 5 mức (90-100 Xuất sắc → 0-39 Chưa đạt) + hành động gợi ý.
model KpiRatingBand {
  id                String   @id @default(cuid())
  frameworkId       String   @map("framework_id")
  label             String
  minScore          Decimal  @map("min_score") @db.Decimal(5, 2)
  maxScore          Decimal  @map("max_score") @db.Decimal(5, 2)
  color             String?
  recommendedAction String?  @map("recommended_action")
  order             Int      @default(0)
  createdAt         DateTime @default(now()) @map("created_at")

  framework KpiFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  @@index([frameworkId])
  @@map("kpi_rating_bands")
}

// Gán framework ↔ phòng ban. Employee → department → framework áp dụng.
model KpiFrameworkAssignment {
  id           String   @id @default(cuid())
  frameworkId  String   @map("framework_id")
  departmentId String   @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")

  framework  KpiFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  department Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([frameworkId, departmentId])
  @@index([departmentId])
  @@map("kpi_framework_assignments")
}

// Chu kỳ chấm KPI (= "run", mirror PayrollRun). configSnapshot đóng băng khi
// finalize → scorecard lịch sử bất biến. Actor ids dùng String? như PayrollRun.
model KpiCycle {
  id             String         @id @default(cuid())
  tenantId       String         @map("tenant_id")
  frameworkId    String         @map("framework_id")
  period         String // "YYYY-MM" hoặc "YYYY-Qn"
  periodType     KpiPeriodType  @map("period_type")
  status         KpiCycleStatus @default(DRAFT)
  configSnapshot Json?          @map("config_snapshot")
  createdById    String?        @map("created_by_id")
  submittedById  String?        @map("submitted_by_id")
  submittedAt    DateTime?      @map("submitted_at")
  finalizedById  String?        @map("finalized_by_id")
  finalizedAt    DateTime?      @map("finalized_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  framework  KpiFramework   @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  scorecards KpiScorecard[]
  entries    KpiEntry[]

  @@unique([tenantId, frameworkId, period])
  @@index([tenantId, status])
  @@map("kpi_cycles")
}

// Phiếu điểm 1 nhân viên / 1 chu kỳ (mirror Payslip). Gồm điểm tính + nhận xét
// 2 chiều (self-assessment + manager review) + routing duyệt.
model KpiScorecard {
  id                String             @id @default(cuid())
  tenantId          String             @map("tenant_id")
  cycleId           String             @map("cycle_id")
  employeeId        String             @map("employee_id")
  weightProfileId   String?            @map("weight_profile_id") // snapshot ref
  weightProfileName String?            @map("weight_profile_name") // snapshot tên
  weightedTotal     Decimal?           @map("weighted_total") @db.Decimal(6, 2)
  ratingLabel       String?            @map("rating_label")
  status            KpiScorecardStatus @default(PENDING)

  // Self-assessment (nhân viên tự đánh giá)
  selfComment     String?   @map("self_comment")
  selfSubmittedAt DateTime? @map("self_submitted_at")

  // Manager review / calibrate
  strengths      String?
  areasToImprove String?   @map("areas_to_improve")
  actionPlan     String?   @map("action_plan")
  recognition    String?
  reviewComment  String?   @map("review_comment")
  reviewerId     String?   @map("reviewer_id")
  reviewedAt     DateTime? @map("reviewed_at")

  // Routing duyệt (tái dùng ApprovalFlow)
  flowId      String? @map("flow_id")
  currentStep Int     @default(0) @map("current_step")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycle     KpiCycle               @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  employee  Employee               @relation("KpiScorecardEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer  Employee?              @relation("KpiScorecardReviewer", fields: [reviewerId], references: [id])
  flow      ApprovalFlow?          @relation(fields: [flowId], references: [id])
  pillars   KpiScorecardPillar[]
  entries   KpiEntry[]
  approvals KpiScorecardApproval[]

  @@unique([cycleId, employeeId])
  @@index([tenantId, status])
  @@index([employeeId])
  @@map("kpi_scorecards")
}

// Điểm tổng hợp theo từng trụ cột trong 1 scorecard (breakdown minh bạch).
model KpiScorecardPillar {
  id          String   @id @default(cuid())
  scorecardId String   @map("scorecard_id")
  pillarId    String   @map("pillar_id")
  score       Decimal? @db.Decimal(6, 2)
  weight      Decimal  @db.Decimal(5, 2) // trọng số áp dụng (từ weight profile)

  scorecard KpiScorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  pillar    KpiPillar    @relation(fields: [pillarId], references: [id], onDelete: Cascade)

  @@unique([scorecardId, pillarId])
  @@index([scorecardId])
  @@map("kpi_scorecard_pillars")
}

// "Ô vàng": giá trị thực tế đo được. scope=INDIVIDUAL → gắn scorecardId;
// scope=TEAM → gắn teamId (chia sẻ xuống mọi member của squad), scorecardId null.
model KpiEntry {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  cycleId         String    @map("cycle_id")
  kpiDefinitionId String    @map("kpi_definition_id")
  scorecardId     String?   @map("scorecard_id") // null cho entry cấp team
  teamId          String?   @map("team_id") // set khi scope=TEAM
  actualValue     Decimal?  @map("actual_value") @db.Decimal(14, 4)
  computedScore   Decimal?  @map("computed_score") @db.Decimal(6, 2)
  source          String? // manual | survey
  note            String?
  enteredById     String?   @map("entered_by_id")
  enteredAt       DateTime? @map("entered_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cycle      KpiCycle      @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  definition KpiDefinition @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade)
  scorecard  KpiScorecard? @relation(fields: [scorecardId], references: [id], onDelete: Cascade)
  team       Team?         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // Invariant scorecard XOR team chốt bằng CHECK constraint (thêm ở migration).
  @@unique([scorecardId, kpiDefinitionId]) // entry cá nhân (PG: null scorecardId không xét)
  @@unique([cycleId, teamId, kpiDefinitionId]) // entry team chia sẻ
  @@index([cycleId])
  @@index([tenantId])
  @@map("kpi_entries")
}

// Timeline duyệt review KPI (snapshot từ ApprovalStep, song song LeaveApproval).
model KpiScorecardApproval {
  id           String            @id @default(cuid())
  tenantId     String            @map("tenant_id")
  scorecardId  String            @map("scorecard_id")
  round        Int               @default(1)
  stepOrder    Int               @map("step_order")
  approverType ApproverType      @map("approver_type")
  roleKey      String?           @map("role_key")
  approverId   String?           @map("approver_id")
  decision     ApprovalDecision? // null = đang chờ
  decidedById  String?           @map("decided_by_id")
  decidedAt    DateTime?         @map("decided_at")
  note         String?
  createdAt    DateTime          @default(now()) @map("created_at")

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scorecard KpiScorecard @relation(fields: [scorecardId], references: [id], onDelete: Cascade)

  @@unique([scorecardId, round, stepOrder])
  @@index([scorecardId])
  @@index([tenantId])
  @@map("kpi_scorecard_approvals")
}

// Mẫu khảo sát Team Health. Ẩn danh: KpiSurveyResponse KHÔNG lưu raterId.
model KpiSurvey {
  id           String        @id @default(cuid())
  tenantId     String        @map("tenant_id")
  frameworkId  String?       @map("framework_id")
  type         KpiSurveyType
  title        String
  isAnonymous  Boolean       @default(true) @map("is_anonymous")
  minResponses Int           @default(3) @map("min_responses") // ngưỡng N mới hiển thị kết quả
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  tenant         Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  framework      KpiFramework?            @relation(fields: [frameworkId], references: [id], onDelete: SetNull)
  questions      KpiSurveyQuestion[]
  responses      KpiSurveyResponse[]
  participations KpiSurveyParticipation[]

  @@index([tenantId])
  @@map("kpi_surveys")
}

model KpiSurveyQuestion {
  id            String  @id @default(cuid())
  surveyId      String  @map("survey_id")
  code          String // M1, P1…
  text          String
  scaleMin      Int     @default(1) @map("scale_min")
  scaleMax      Int     @default(10) @map("scale_max")
  mapsToKpiCode String? @map("maps_to_kpi_code") // khớp KpiDefinition.surveyKpiCode (T1/T2)
  order         Int     @default(0)

  survey KpiSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, code])
  @@index([surveyId])
  @@map("kpi_survey_questions")
}

// Phản hồi survey — ẩn danh: KHÔNG có raterId. subjectEmployeeId chỉ dùng cho
// 360° peer (người ĐƯỢC đánh giá), không lộ ai chấm.
model KpiSurveyResponse {
  id                String   @id @default(cuid())
  tenantId          String   @map("tenant_id")
  surveyId          String   @map("survey_id")
  cycleId           String?  @map("cycle_id")
  subjectEmployeeId String?  @map("subject_employee_id") // 360: người được đánh giá
  answers           Json // { [questionCode]: number }
  createdAt         DateTime @default(now()) @map("created_at")

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  survey KpiSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@index([surveyId])
  @@index([tenantId])
  @@map("kpi_survey_responses")
}

// Sổ tham gia survey — chống ballot-stuffing: ghi AI đã trả lời (userId) nhưng
// KHÔNG ghi trả lời GÌ (answers nằm ở KpiSurveyResponse, không liên kết). Unique
// (survey, cycle, user) ép mỗi người 1 lần/kỳ mà vẫn giữ phản hồi ẩn danh.
model KpiSurveyParticipation {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  surveyId  String   @map("survey_id")
  cycleId   String?  @map("cycle_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  survey KpiSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, cycleId, userId])
  @@index([tenantId])
  @@map("kpi_survey_participations")
}

// =============================================================================
// SPEC-045: Sales / CRM (B2B + B2C)
// Tách Customer (vòng đời lead, ownership) khỏi Deal (cơ hội, stage pipeline).
// Tiền dùng Decimal(18,2). owner/assignee/author/sender -> Employee.
// =============================================================================

enum CustomerType {
  B2B
  B2C
}

enum CustomerLifecycle {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  CUSTOMER
  DISQUALIFIED
}

enum LeadSource {
  WEB
  REFERRAL
  COLD_CALL
  COLD_EMAIL
  EVENT
  SOCIAL
  ADVERTISING
  PARTNER
  IMPORT
  OTHER
}

enum SalesStageType {
  NEW
  QUALIFYING
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum SalesActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  STAGE_CHANGED
  OWNER_CHANGED
  STATUS_CHANGED
  LIFECYCLE_CHANGED
}

enum SalesTaskType {
  CALL
  EMAIL
  MEETING
  TODO
}

enum SalesTaskStatus {
  OPEN
  DONE
  CANCELLED
}

enum SalesEmailStatus {
  QUEUED
  SENT
  FAILED
  OPENED // Tier 2
  CLICKED // Tier 2
}

// Tổ chức (B2B). B2C bỏ trống — Customer không gắn company.
model SalesCompany {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  taxCode   String?  @map("tax_code")
  industry  String?
  size      String?
  website   String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customers Customer[]

  @@index([tenantId])
  @@map("sales_companies")
}

// Khách hàng / lead thống nhất. lifecycleStatus = trục "có đáng theo đuổi không".
model Customer {
  id              String            @id @default(cuid())
  tenantId        String            @map("tenant_id")
  type            CustomerType      @default(B2C)
  companyId       String?           @map("company_id")
  fullName        String            @map("full_name")
  title           String?
  email           String?
  phone           String? // chuẩn hóa E.164 ở service để dedupe
  address         String?
  source          LeadSource        @default(OTHER)
  lifecycleStatus CustomerLifecycle @default(NEW) @map("lifecycle_status")
  lostReason      String?           @map("lost_reason")
  ownerId         String?           @map("owner_id") // null = Lead Pool
  assignedAt      DateTime?         @map("assigned_at")
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company    SalesCompany?       @relation(fields: [companyId], references: [id])
  owner      Employee?           @relation("CustomerOwner", fields: [ownerId], references: [id])
  deals      Deal[]
  activities SalesActivity[]
  tasks      SalesTask[]
  emails     SalesEmailMessage[]

  @@index([tenantId, lifecycleStatus])
  @@index([tenantId, ownerId])
  @@index([companyId])
  @@map("customers")
}

// Pipeline cấp tenant (hỗ trợ nhiều — Giai đoạn 1 seed 1 cái mặc định).
model SalesPipeline {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages SalesStage[]
  deals  Deal[]

  @@unique([tenantId, name])
  @@map("sales_pipelines")
}

model SalesStage {
  id          String         @id @default(cuid())
  pipelineId  String         @map("pipeline_id")
  name        String
  order       Int
  type        SalesStageType
  probability Int            @default(0) // % cho forecast

  pipeline    SalesPipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals       Deal[]
  fromHistory DealStageHistory[] @relation("DealFromStage")
  toHistory   DealStageHistory[] @relation("DealToStage")

  @@unique([pipelineId, order])
  @@map("sales_stages")
}

// Cơ hội bán hàng. stage = trục "thương vụ đang tới đâu". amount đồng bộ từ Quote chính.
model Deal {
  id                String     @id @default(cuid())
  tenantId          String     @map("tenant_id")
  customerId        String     @map("customer_id")
  pipelineId        String     @map("pipeline_id")
  currentStageId    String     @map("current_stage_id")
  ownerId           String     @map("owner_id")
  title             String
  amount            Decimal    @default(0) @db.Decimal(18, 2) // = tổng báo giá chính
  currency          String     @default("VND")
  status            DealStatus @default(OPEN)
  expectedCloseDate DateTime?  @map("expected_close_date")
  wonAt             DateTime?  @map("won_at")
  lostAt            DateTime?  @map("lost_at")
  lostReason        String?    @map("lost_reason")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer          Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  pipeline          SalesPipeline       @relation(fields: [pipelineId], references: [id])
  currentStage      SalesStage          @relation(fields: [currentStageId], references: [id])
  owner             Employee            @relation("DealOwner", fields: [ownerId], references: [id])
  stageHistory      DealStageHistory[]
  quotes            Quote[]
  activities        SalesActivity[]
  tasks             SalesTask[]
  SalesEmailMessage SalesEmailMessage[]

  @@index([tenantId, pipelineId, currentStageId])
  @@index([tenantId, ownerId])
  @@index([customerId])
  @@map("deals")
}

// Lịch sử chuyển stage — build NGAY cho analytics velocity/conversion.
model DealStageHistory {
  id          String   @id @default(cuid())
  dealId      String   @map("deal_id")
  fromStageId String?  @map("from_stage_id")
  toStageId   String   @map("to_stage_id")
  changedById String?  @map("changed_by_id") // null = hệ thống / admin không gắn hồ sơ NV
  note        String?
  changedAt   DateTime @default(now()) @map("changed_at")

  deal      Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStage SalesStage? @relation("DealFromStage", fields: [fromStageId], references: [id])
  toStage   SalesStage  @relation("DealToStage", fields: [toStageId], references: [id])
  changedBy Employee?   @relation("DealStageChanger", fields: [changedById], references: [id])

  @@index([dealId])
  @@map("deal_stage_history")
}

model Product {
  id          String        @id @default(cuid())
  tenantId    String        @map("tenant_id")
  name        String
  sku         String?
  description String?
  unitPrice   Decimal       @default(0) @map("unit_price") @db.Decimal(18, 2)
  currency    String        @default("VND")
  unit        String?
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quoteItems QuoteItem[]

  @@unique([tenantId, sku])
  @@map("products")
}

model Quote {
  id              String      @id @default(cuid())
  tenantId        String      @map("tenant_id")
  dealId          String      @map("deal_id")
  issuingEntityId String?     @map("issuing_entity_id")
  code            String
  status          QuoteStatus @default(DRAFT)
  isPrimary       Boolean     @default(true) @map("is_primary") // báo giá chính -> Deal.amount
  validUntil      DateTime?   @map("valid_until")
  total           Decimal     @default(0) @db.Decimal(18, 2) // = Σ items (đồng bộ ở service)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deal          Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  issuingEntity IssuingEntity? @relation(fields: [issuingEntityId], references: [id])
  items         QuoteItem[]

  @@index([dealId])
  @@map("quotes")
}

model QuoteItem {
  id          String  @id @default(cuid())
  quoteId     String  @map("quote_id")
  productId   String? @map("product_id") // null = dòng tự do
  description String?
  quantity    Decimal @default(1) @db.Decimal(18, 2)
  unitPrice   Decimal @default(0) @map("unit_price") @db.Decimal(18, 2)
  discountPct Decimal @default(0) @map("discount_pct") @db.Decimal(5, 2)
  lineTotal   Decimal @default(0) @map("line_total") @db.Decimal(18, 2) // tính ra ở service

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([quoteId])
  @@map("quote_items")
}

// Timeline: note thủ công + sự kiện hệ thống (stage/owner/status/lifecycle/email).
model SalesActivity {
  id         String            @id @default(cuid())
  tenantId   String            @map("tenant_id")
  customerId String            @map("customer_id")
  dealId     String?           @map("deal_id")
  authorId   String?           @map("author_id") // null = hệ thống
  type       SalesActivityType
  body       String?
  occurredAt DateTime          @default(now()) @map("occurred_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deal     Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  author   Employee? @relation("SalesActivityAuthor", fields: [authorId], references: [id])

  @@index([customerId])
  @@index([dealId])
  @@map("sales_activities")
}

// Việc follow-up có hạn — nhắc tự động qua BullMQ (domain/reminders).
model SalesTask {
  id          String          @id @default(cuid())
  tenantId    String          @map("tenant_id")
  customerId  String          @map("customer_id")
  dealId      String?         @map("deal_id")
  assigneeId  String          @map("assignee_id")
  type        SalesTaskType   @default(TODO)
  title       String
  dueAt       DateTime        @map("due_at")
  status      SalesTaskStatus @default(OPEN)
  completedAt DateTime?       @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deal     Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  assignee Employee @relation("SalesTaskAssignee", fields: [assigneeId], references: [id])

  @@index([tenantId, assigneeId, status])
  @@index([dueAt])
  @@map("sales_tasks")
}

model SalesEmailTemplate {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  subject   String
  body      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  messages SalesEmailMessage[]

  @@unique([tenantId, name])
  @@map("sales_email_templates")
}

model SalesEmailMessage {
  id         String           @id @default(cuid())
  tenantId   String           @map("tenant_id")
  customerId String           @map("customer_id")
  dealId     String?          @map("deal_id")
  templateId String?          @map("template_id")
  to         String
  subject    String
  body       String
  status     SalesEmailStatus @default(QUEUED)
  sentById   String?          @map("sent_by_id") // null = hệ thống / admin không gắn hồ sơ NV
  sentAt     DateTime?        @map("sent_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deal     Deal?               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  template SalesEmailTemplate? @relation(fields: [templateId], references: [id])
  sentBy   Employee?           @relation("SalesEmailSender", fields: [sentById], references: [id])

  @@index([customerId])
  @@map("sales_email_messages")
}

// ============================================================================
// SPEC-048: Ngân sách & Dòng tiền (Budget & Cash Flow) — GĐ1 (MVP)
// ============================================================================

enum TransactionDirection {
  IN
  OUT
}

// ACTUAL = đã phát sinh (ảnh hưởng số dư & báo cáo).
// PLANNED = dự kiến (chỉ feed dự báo GĐ2, KHÔNG đụng số dư).
enum TransactionStatus {
  ACTUAL
  PLANNED
}

enum CategoryKind {
  INCOME
  EXPENSE
}

enum FundAccountType {
  BANK
  CASH
  EWALLET
}

enum TransactionSource {
  MANUAL
  IMPORT
  PAYMENT_REQUEST
  PURCHASE_REQUEST
  PAYROLL
}

// Tài khoản quỹ: nơi chứa tiền (TK ngân hàng / tiền mặt / ví). Số dư hiện tại KHÔNG
// nhập tay — luôn = openingBalance + Σ(IN actual) − Σ(OUT actual), recompute nguyên tử.
model FundAccount {
  id              String          @id @default(cuid())
  tenantId        String          @map("tenant_id")
  issuingEntityId String          @map("issuing_entity_id") // pháp nhân sở hữu quỹ (SPEC-043)
  name            String
  type            FundAccountType @default(BANK)
  currency        String          @default("VND")
  openingBalance  Decimal         @default(0) @map("opening_balance") @db.Decimal(14, 2)
  currentBalance  Decimal         @default(0) @map("current_balance") @db.Decimal(14, 2) // denormalized
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  issuingEntity IssuingEntity     @relation(fields: [issuingEntityId], references: [id])
  transactions  CashTransaction[]
  topUpRequests TopUpRequest[] // SPEC-048 GĐ3 (funded account)

  @@index([tenantId, issuingEntityId])
  @@map("fund_accounts")
}

// Danh mục thu/chi phân cấp (tối đa 2 cấp qua parentId). kind tách INCOME vs EXPENSE.
model FinanceCategory {
  id        String       @id @default(cuid())
  tenantId  String       @map("tenant_id")
  kind      CategoryKind
  name      String
  parentId  String?      @map("parent_id")
  active    Boolean      @default(true)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent       FinanceCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children     FinanceCategory[] @relation("CategoryTree")
  transactions CashTransaction[]
  planItems    SpendingPlanItem[] // SPEC-048 GĐ2

  @@index([tenantId, kind])
  @@map("finance_categories")
}

// Sổ giao dịch: 1 dòng thu (IN) hoặc chi (OUT). ACTUAL đụng số dư; PLANNED chỉ dự báo.
model CashTransaction {
  id              String               @id @default(cuid())
  tenantId        String               @map("tenant_id")
  accountId       String               @map("account_id")
  issuingEntityId String               @map("issuing_entity_id")
  direction       TransactionDirection
  status          TransactionStatus    @default(ACTUAL)
  amount          Decimal              @db.Decimal(14, 2)
  currency        String               @default("VND")
  occurredAt      DateTime             @map("occurred_at") // ngày phát sinh / dự kiến
  categoryId      String?              @map("category_id")
  departmentId    String?              @map("department_id")
  description     String?
  reference       String? // số chứng từ / mã chuyển khoản
  source          TransactionSource    @default(MANUAL)
  sourceRefId     String?              @map("source_ref_id") // nối PR/Payment/Payroll (GĐ4)
  createdById     String               @map("created_by_id")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account       FundAccount      @relation(fields: [accountId], references: [id])
  issuingEntity IssuingEntity    @relation(fields: [issuingEntityId], references: [id])
  category      FinanceCategory? @relation(fields: [categoryId], references: [id])
  department    Department?      @relation(fields: [departmentId], references: [id])

  @@index([tenantId, issuingEntityId, occurredAt])
  @@index([accountId, status])
  @@index([categoryId])
  @@map("cash_transactions")
}

// ============================================================================
// SPEC-048 GĐ2: Kế hoạch chi theo bộ phận (Spending Plan)
// ============================================================================

enum SpendingPlanStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

// Kế hoạch chi của một bộ phận cho một kỳ (tháng), theo pháp nhân. Trưởng bộ phận
// nhập & gửi; HR/Finance duyệt. Feed vào dự báo dòng tiền khi APPROVED.
model SpendingPlan {
  id              String             @id @default(cuid())
  tenantId        String             @map("tenant_id")
  departmentId    String?            @map("department_id") // GĐ2': nhãn tùy chọn (mặc định phòng người tạo)
  issuingEntityId String             @map("issuing_entity_id")
  period          String // "YYYY-MM"
  status          SpendingPlanStatus @default(DRAFT)
  totalAmount     Decimal            @default(0) @map("total_amount") @db.Decimal(14, 2) // denormalized = Σ items
  submittedById   String?            @map("submitted_by_id")
  submittedAt     DateTime?          @map("submitted_at")
  reviewedById    String?            @map("reviewed_by_id")
  reviewedAt      DateTime?          @map("reviewed_at")
  reviewNote      String?            @map("review_note")
  createdById     String             @map("created_by_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department    Department?        @relation(fields: [departmentId], references: [id])
  issuingEntity IssuingEntity      @relation(fields: [issuingEntityId], references: [id])
  items         SpendingPlanItem[]

  // GĐ2': ai cũng lập được (đề xuất theo người tạo) — bỏ giới hạn 1 kế hoạch/phòng/kỳ.
  @@index([tenantId, period, status])
  @@index([createdById])
  @@map("spending_plans")
}

model SpendingPlanItem {
  id           String    @id @default(cuid())
  planId       String    @map("plan_id")
  categoryId   String?   @map("category_id")
  title        String
  amount       Decimal   @db.Decimal(14, 2)
  expectedDate DateTime? @map("expected_date")
  note         String?

  plan     SpendingPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  category FinanceCategory? @relation(fields: [categoryId], references: [id])

  @@index([planId])
  @@map("spending_plan_items")
}

// ============================================================================
// SPEC-048 GĐ3: Đề xuất nạp quỹ (Top-up Request)
// ============================================================================

enum TopUpStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// HR/Finance lập đề xuất nạp thêm tiền vào quỹ (kèm giải trình); Founder duyệt.
// Khi duyệt kèm tài khoản → tự sinh giao dịch IN "Nạp quỹ" và tính lại số dư.
model TopUpRequest {
  id              String      @id @default(cuid())
  tenantId        String      @map("tenant_id")
  issuingEntityId String      @map("issuing_entity_id")
  title           String
  amount          Decimal     @db.Decimal(14, 2)
  currency        String      @default("VND")
  neededByDate    DateTime?   @map("needed_by_date")
  period          String? // "YYYY-MM" kỳ liên quan (cho giải trình)
  justification   String // giải trình (tự sinh + sửa được)
  status          TopUpStatus @default(PENDING)
  reviewedById    String?     @map("reviewed_by_id")
  reviewedAt      DateTime?   @map("reviewed_at")
  reviewNote      String?     @map("review_note")
  fundedAccountId String?     @map("funded_account_id") // tài khoản được nạp khi duyệt
  fundedAt        DateTime?   @map("funded_at")
  createdById     String      @map("created_by_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  issuingEntity IssuingEntity @relation(fields: [issuingEntityId], references: [id])
  fundedAccount FundAccount?  @relation(fields: [fundedAccountId], references: [id])

  @@index([tenantId, status])
  @@map("topup_requests")
}
