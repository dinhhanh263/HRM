# Test environment — loaded by vitest.config.ts (loadEnv mode "test").
# Values here OVERRIDE .env so the test suite never touches hrm_dev or
# external services. Create/migrate the test DB with: npm run test:db:setup

# Database — dedicated test database, wiped per-tenant by each suite
DATABASE_URL="postgresql://hrm:hrm_secret@localhost:5432/hrm_test?schema=public"

# Redis — separate logical DB so test queues never mix with the dev API's
REDIS_URL="redis://localhost:6379/1"

# JWT — must match the value tests/setup.ts forces in beforeAll
JWT_SECRET="test-secret-key"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Email — empty key makes the Resend provider take its warn-and-skip no-op path
RESEND_API_KEY=""
EMAIL_FROM="HRM Test <no-reply@test.local>"

# Rate limiting — disabled so suites that hammer /auth (login in beforeAll, etc.)
# never hit 429. The rate-limit suite re-enables it per-request via process.env.
RATE_LIMIT_DISABLED="true"
