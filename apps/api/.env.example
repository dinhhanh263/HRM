# Database
DATABASE_URL="postgresql://hrm:hrm_secret@localhost:5432/hrm_dev?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Email (Resend) — invite emails for bulk-imported employees.
# When RESEND_API_KEY is empty, invite emails are skipped (logged) instead of failing.
# Production: use a real key + a verified sending domain (not onboarding@resend.dev).
RESEND_API_KEY=""
EMAIL_FROM="HRM <onboarding@resend.dev>"
APP_WEB_URL="http://localhost:5173"

# Google Workspace SSO (OAuth 2.0). Create an OAuth Client ID (Web application)
# in Google Cloud Console → APIs & Services → Credentials. When CLIENT_ID/SECRET
# are empty, the /auth/google routes return a clean "SSO not configured" error.
# The redirect URI below MUST be registered verbatim in the Google console.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Goes through the Vite dev origin (:5173) so the refresh cookie lands on the
# SPA's origin. Register this exact URI in the Google console.
GOOGLE_REDIRECT_URI="http://localhost:5173/api/v1/auth/google/callback"
# Frontend bounce page after a successful callback (reads the refresh cookie).
GOOGLE_SUCCESS_REDIRECT="http://localhost:5173/auth/google/success"
# Where failed SSO attempts land (a neutral ?error code is appended).
GOOGLE_FAILURE_REDIRECT="http://localhost:5173/login"

# Rate limiting (SPEC-038) — auth endpoints allow 5 requests / 15 min per
# (route, IP, email). Set to "true" only in test/dev when the limiter gets in the way.
RATE_LIMIT_DISABLED="false"

# CV storage (SPEC-039). `local` (default) writes to disk under CV_STORAGE_DIR —
# fine for dev/test. `gcs` stores CVs in Google Cloud Storage for production.
STORAGE_DRIVER="local"
# CV_STORAGE_DIR="storage/cv"   # only used when STORAGE_DRIVER=local
# When STORAGE_DRIVER=gcs:
#  - GCS_BUCKET is required (the driver fails fast at boot if missing).
#  - Auth uses Application Default Credentials — NO static keys. On GCP the
#    Cloud Run/GKE service account (Workload Identity) is used automatically;
#    locally run `gcloud auth application-default login`.
#  - GCP_PROJECT_ID is optional when ADC can infer the project.
GCS_BUCKET=""
GCP_PROJECT_ID=""
