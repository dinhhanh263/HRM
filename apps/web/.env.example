# Web app environment variables. Copy to `.env` (or `.env.local`) and adjust.

# Base URL of the backend API. Defaults to /api/v1 (proxied) when unset.
VITE_API_URL=/api/v1

# Dev only: by default `pnpm dev` auto-logs-in as a mock HR_MANAGER with every
# permission so the full UI is visible without a backend. Set this to "true" to
# disable that and hit the real login flow — required to test role-based
# permissions (log in as the seeded SUPER_ADMIN / HR_MANAGER / MANAGER / EMPLOYEE
# accounts). Has no effect in production builds.
VITE_DISABLE_DEV_AUTH=false
